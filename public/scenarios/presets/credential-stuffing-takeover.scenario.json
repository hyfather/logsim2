  "reasoning": "Public Nginx → auth-api + users-api → Postgres + Redis. Auth API sees the brute force, users-api shows the compromise, DB lights up with anomalous lateral queries.",
  "category": "security",
  "difficulty": "hard",
  "nodes": [
    { "id": "vpc",     "type": "vpc",     "label": "prod-vpc",      "parent": null },
    { "id": "pubnet",  "type": "subnet",  "label": "public-subnet", "parent": "vpc" },
    { "id": "appnet",  "type": "subnet",  "label": "app-subnet",    "parent": "vpc" },
    { "id": "datanet", "type": "subnet",  "label": "data-subnet",   "parent": "vpc" },
    { "id": "lb",     "type": "service", "serviceType": "nginx",    "label": "edge-lb",   "parent": "pubnet" },
