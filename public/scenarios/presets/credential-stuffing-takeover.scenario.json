    { "source": "auth",  "target": "db",    "protocol": "tcp",  "port": 5432, "trafficRate": 30,  "trafficPattern": "steady",  "errorRate": 0.001 },
    { "source": "users", "target": "db",    "protocol": "tcp",  "port": 5432, "trafficRate": 50,  "trafficPattern": "steady",  "errorRate": 0.001 },
